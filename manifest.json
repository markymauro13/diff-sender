{
  "manifest_version": 3,
  "name": "Diff Sender",
  "description": "Copy merge request diffs to your clipboard or download them — optimized for pasting into LLMs.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gitlab.com/*/-/merge_requests/*",
        "*://*/*/-/merge_requests/*",
        "*://github.com/*/pull/*",
        "*://*.github.com/*/pull/*",
        "*://*.atlassian.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
